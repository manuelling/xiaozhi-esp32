# M5Stack Core2 ESP32 Configuration for xiaozhi-esp32
# GPIO and Hardware Configuration for M5Core2 (ESP32-D0WDQ6-V3)

# CPU and Memory Configuration
CONFIG_IDF_TARGET="esp32"
CONFIG_ESP32_REV_MIN=1
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_SIZE=8388608
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_USE_MEMSET=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384

# I2S Audio Configuration for M5Core2
# Microphone: SPM1423 (GPIO34 I2S_IN, GPIO0 CLK)
# Speaker: NS4168 + 1W (GPIO26 I2S_OUT, GPIO4 BCLK, GPIO25 LRCK)
CONFIG_I2S_SUPPORT_INTERNAL_DAC=y
CONFIG_I2S_NUM_0=y

# I2S Pin Configuration (GPIO mapping)
CONFIG_I2S_BCK_PIN=4          # BCLK (GPIO4)
CONFIG_I2S_WS_PIN=25          # LRCK (GPIO25)
CONFIG_I2S_DO_PIN=26          # DATA_OUT to Speaker (GPIO26)
CONFIG_I2S_DI_PIN=34          # DATA_IN from Microphone (GPIO34)
CONFIG_I2S_MCLK_PIN=0         # Master Clock for microphone

# Display Configuration - ILI9342C 320x240 LCD
CONFIG_ILI9341_SPI_HOST_SEL=1 # SPI2
CONFIG_LV_DISP_SPI_MOSI=23    # GPIO23
CONFIG_LV_DISP_SPI_MISO=38    # GPIO38
CONFIG_LV_DISP_SPI_CLK=18     # GPIO18
CONFIG_LV_DISP_SPI_CS=5       # GPIO5 (CS)
CONFIG_LV_DISP_PIN_DC=15      # GPIO15 (DC)
CONFIG_LV_DISP_PIN_RST=1      # GPIO1 (RST)
CONFIG_LV_DISP_PIN_BL=12      # GPIO12 (Backlight)

# Touch Screen Configuration - FT6336U
CONFIG_LV_TOUCH_I2C_PORT=1
CONFIG_LV_TOUCH_I2C_SDA=21    # GPIO21
CONFIG_LV_TOUCH_I2C_SCL=22    # GPIO22
CONFIG_FT6336U_I2C_ADDR=0x38

# WiFi Configuration - ASUS_MJ Network
CONFIG_WIFI_SSID="ASUS_MJ"
CONFIG_WIFI_PASSWORD="5544332211"
CONFIG_WIFI_AUTH_OPEN=n
CONFIG_WIFI_AUTH_WEP=n
CONFIG_WIFI_AUTH_WPA_PSK=y
CONFIG_WIFI_AUTH_WPA2_PSK=y
CONFIG_WIFI_AUTH_WPA_WPA2_PSK=y
CONFIG_WIFI_INIT_AP_MODE=n

# Bluetooth Configuration (optional for BLE pairing)
CONFIG_BT_ENABLED=n
CONFIG_BTDM_CTRL_MODE_BLE_ONLY=n
CONFIG_BTDM_CTRL_MODE_BR_EDR_ONLY=n

# USB Configuration (for debugging/flashing)
CONFIG_USB_DEVICE_ENABLED=n

# UART Configuration for Serial Monitor
CONFIG_UART_PRINT_TX_PIN=1
CONFIG_UART_PRINT_RX_PIN=3

# Logging Configuration - Color-Coded Output
CONFIG_LOG_COLORS=y
CONFIG_LOG_DEFAULT_LEVEL=4    # INFO level
CONFIG_LOG_LEVEL_APPLICATION=4
CONFIG_LOG_LEVELS_DEBUG=n
CONFIG_LOG_BUFFER_LEN=256

# Boot Configuration
CONFIG_BOOTLOADER_WDT_ENABLE=n
CONFIG_BOOTLOADER_SKIP_VALIDATE_IN_DEEP_SLEEP=y
CONFIG_BOOTLOADER_VDDSDIO_BOOST=y

# Power Configuration
CONFIG_ESP32_DEFAULT_CPU_FREQ_240=y
CONFIG_ESP32_DEFAULT_CPU_FREQ_MHZ=240

# Storage Configuration
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/partitions_custom.csv"

# OTA Update Configuration
CONFIG_APP_ROLLBACK_ENABLE=y
CONFIG_APP_ROLLBACK_ALWAYS=n

# mDNS Configuration (optional)
CONFIG_MDNS_ENABLE=y

# Security Configuration
CONFIG_SECURE_BOOT_ENABLED=n
CONFIG_FLASH_ENCRYPTION_ENABLED=n

# Miscellaneous
CONFIG_FREERTOS_UNICORE=n
CONFIG_FREERTOS_TICK_RATE_HZ=1000
CONFIG_DEEP_SLEEP_WAKEUP_DELAY=2000
CONFIG_ESP_SLEEP_DEBUG=n

# xiaozhi-esp32 Framework Configuration
CONFIG_ESPRESSIF_ESP_SPEECH_RECOGNITION=y
CONFIG_ESP32_WIFI_STATIC_TX_BUFFER_NUM=16
CONFIG_ESP32_WIFI_DYNAMIC_TX_BUFFER_NUM=32
CONFIG_USE_ONLY_LVGL_72=n
